OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

# 可选：如果你不想抓全市场，先放一个自定义观察池
WATCHLIST=600519,000001,300750
WATCHLIST_FILE=watchlist.txt

# 选股范围与行业偏好
UNIVERSE_MODE=full
# 赛道别名说明：左边是输出到报告里的赛道名，右边是命中的关键词，多个关键词用 | 分隔
SECTOR_KEYWORD_ALIASES=半导体=半导体|芯片|集成电路|存储|封测|晶圆|设备;算力=算力|服务器|液冷|GPU|AI服务器|IDC;光模块=光模块|CPO|800G|100G;通信=通信|5G|6G|光通信|光纤;AI=AI|人工智能|大模型|算法;电子=电子|消费电子|元器件|PCB;软件=软件|SaaS|应用软件|云计算
PREFERRED_SECTOR_KEYWORDS=科技,电子,半导体,算力,AI,软件,芯片,通信,消费电子,光模块
SECTOR_KEYWORD_WEIGHTS=科技:4,电子:6,半导体:12,算力:11,AI:10,软件:6,芯片:11,通信:8,消费电子:5,光模块:12
SECTOR_BOOST=8
PICK_TOP_N=10
PICK_EXPORT_CSV=outputs/picked_stocks.csv

# 输出目录
# 例如：/Users/你的用户名/Desktop/a-share-ai-system-output
OUTPUT_DIR=~/Desktop/a-share-ai-system-output
DESKTOP_OUTPUT=true
OPEN_DASHBOARD_HTML=true

# 数据缓存与重试
DATA_CACHE_DIR=cache
DATA_MAX_RETRIES=5
DATA_RETRY_MIN_SECONDS=2
DATA_RETRY_MAX_SECONDS=5
DATA_USE_BAOSTOCK=true

# 通知
NOTIFY_PROVIDER=serverchan
NOTIFY_WEBHOOK_URL=

# 邮件通知（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
