OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini

# 可选：如果你不想抓全市场，先放一个自定义观察池
WATCHLIST=600519,000001,300750
WATCHLIST_FILE=watchlist.txt

# 输出目录
# 例如：/Users/你的用户名/Desktop/a-share-ai-system-output
OUTPUT_DIR=~/Desktop/a-share-ai-system-output

# 通知
NOTIFY_PROVIDER=serverchan
NOTIFY_WEBHOOK_URL=

# 邮件通知（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TO=
